{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Standards Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "profile",
    "languages",
    "disciplines"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "disciplines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
