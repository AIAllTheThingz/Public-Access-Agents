{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Test Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "testType",
    "command",
    "result"
  ],
  "properties": {
    "testType": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "result": {
      "enum": [
        "passed",
        "failed",
        "not-run"
      ]
    },
    "environment": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
